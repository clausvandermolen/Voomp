# ─── Required ───────────────────────────────────────────────────
# Active Supabase project (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Optional ───────────────────────────────────────────────────
# hCaptcha site key — used for sign-up and sign-in. Leave unset to
# bypass captcha entirely (dev only). https://dashboard.hcaptcha.com
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
